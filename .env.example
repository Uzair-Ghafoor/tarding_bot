# Copy to .env on AWS — never commit .env

MT5_LOGIN=123456789
MT5_PASSWORD=YourTradingPassword
MT5_SERVER=Exness-MT5Trial16

MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_SYMBOL=XAUUSDT
MT5_PAPER_PAIRS=XAUUSDT
MT5_SYMBOL_FALLBACKS=XAUUSDT,XAUUSDTm

# Size risk as $30 account (Exness demo may show $500k — that's OK)
MT5_REFERENCE_BALANCE=30
MT5_LOT=0.01
MT5_BASKET_SIZE=10

# Fallback fixed targets ($30 scale) — ATR math overrides when MT5_USE_ATR_TARGETS=true
MT5_BASKET_MIN_PROFIT=0.45
MT5_BASKET_MAX_LOSS=0.90

# Quant math
MT5_USE_ATR_TARGETS=true
MT5_ATR_TP_MULT=0.35
MT5_ATR_SL_MULT=0.70
MT5_RISK_PCT=0.03
MT5_KELLY_FRAC=0.5
MT5_MIN_BASKETS_KELLY=8
MT5_MIN_BASKETS_EV=6
MT5_MIN_EV=0
MT5_USE_EV_GATE=true
MT5_ADX_MIN=22
MT5_ATR_SPIKE=2.0
MT5_ZSCORE_MAX=0.85

# Sell-side tuning — Step 2 (deploy / anti-whipsaw)
# Step 1: MAX_SELL=2.5 RELAX=1 EMA_TOL=0.006
# Step 2: MAX_SELL=1.8 + relax blocked when Z<-2 + post-SL cooldown
MT5_ZSCORE_MAX_SELL=1.8
MT5_M5_SELL_RELAX=1
MT5_M5_SELL_EMA_TOL=0.006
MT5_M5_SELL_RELAX_Z_FLOOR=-2.0
MT5_POST_SL_COOLDOWN=75
MT5_STARTUP_WARMUP_SCANS=3
MT5_ATR_SL_VOL_THRESHOLD=1.75
MT5_ATR_SL_VOL_BOOST=1.25

# Stricter entries (H1+M15+M5 pullback, RSI 40-65)
MT5_MIN_SCORE=75
MT5_MIN_SCORE_FALLBACK=85
MT5_M5_FALLBACK=true
MT5_REQUIRE_H1=true

# Paper observe mode — looser H1 (M15 can trade against H1 with score penalty)
# MT5_BLOCK_H1_CONFLICT=false
# MT5_H1_EMA_TOL=0.0008
# MT5_RSI_BUY_MAX=72
# MT5_RSI_SELL_MIN=28

# Basket exit — bar_range uses M5 hi/lo since entry (~matches backtest, higher WR)
# MT5_EXIT_MODE=bar_range
# MT5_EXIT_MODE=tick
# MT5_SL_DELAY=0

# Execution — no broker SL (basket manages risk)
MT5_STOP_LOSS_POINTS=0
MT5_MAX_SPREAD_POINTS=45
MT5_ENTRY_COOLDOWN=15
MT5_POST_BASKET_COOLDOWN=60

# Binance paper fees (taker on each market fill + live bid-ask spread)
MT5_BINANCE_TAKER_FEE=0.001
MT5_PAPER_NOTIONAL_MULT=10
MT5_MAX_DAILY_LOSS=0
MT5_USE_LOSS_PAUSE=false
MT5_USE_SESSION=false

MT5_POLL_SECONDS=0.5
# Fast tick while basket is open (paper autopilot + dashboard)
MT5_BASKET_PRICE_SEC=0.25

# Autopilot AI brain (Mac paper mode) — get key at console.anthropic.com
# AGENT_BRAIN=rules          # default now (no API needed)
# AGENT_BRAIN=claude         # production with real money after adding key below
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Binance Futures testnet — real test orders on XAUUSDT (not spot testnet)
# 1) Register at https://testnet.binancefuture.com/
# 2) API Management → create key (enable futures trading)
# 3) Fund test wallet from the testnet UI (free USDT)
BINANCE_TESTNET=true
# BINANCE_API_KEY=your_testnet_key
# BINANCE_API_SECRET=your_testnet_secret
BINANCE_SYMBOL=XAUUSDT
BINANCE_LEVERAGE=5

# Paper VPS — for npm run pull-logs from your Mac
# PAPER_HOST=ubuntu@YOUR_ORACLE_VPS_IP
# PAPER_REMOTE_DIR=~/scalpbot
