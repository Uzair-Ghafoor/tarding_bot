{
  "name": "scalpbot",
  "version": "1.0.0",
  "private": true,
  "description": "Exness MT5 basket scalping bot — paper + live",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "stop": "bash scripts/stop.sh",
    "logs": "tail -f logs/autopilot.log",
    "pull-logs": "bash scripts/pull-logs.sh",
    "paper-status": "python3 scripts/paper-status.py",
    "dashboard": "streamlit run dashboard.py --server.port 8501",
