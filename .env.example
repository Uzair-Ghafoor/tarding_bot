# Copy to .env on AWS — never commit .env

MT5_LOGIN=123456789
MT5_PASSWORD=YourTradingPassword
MT5_SERVER=Exness-MT5Trial16

MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_SYMBOL=XAUUSDm
MT5_SYMBOL_FALLBACKS=XAUUSD,XAUUSDm

# Size risk as $30 account (Exness demo may show $500k — that's OK)
MT5_REFERENCE_BALANCE=30
MT5_LOT=0.01
MT5_BASKET_SIZE=10

# Close ALL 10 together when combined profit/loss hits these ($30 scale)
# Leave 0 to auto-calc: profit ~$0.45, stop ~$0.90
MT5_BASKET_MIN_PROFIT=0.45
MT5_BASKET_MAX_LOSS=0.90

MT5_MIN_SCORE=70
MT5_MAX_SPREAD_POINTS=65
MT5_STOP_LOSS_POINTS=250
MT5_ENTRY_COOLDOWN=30

# Demo testing — no daily cap, no loss pause
MT5_MAX_DAILY_LOSS=0
MT5_USE_LOSS_PAUSE=false
MT5_USE_SESSION=false

MT5_DEMO_ONLY=true
