# ============================================================
# Copy this file to .env and fill YOUR values (never commit .env)
# Exness Personal Area → My accounts → expand MT5 demo card
# https://my.exness.com
# ============================================================

MT5_LOGIN=123456789
MT5_PASSWORD=YourTradingPassword
MT5_SERVER=Exness-MT5Trial9

MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Symbol — copy EXACT name from MT5 Market Watch
MT5_SYMBOL=XAUUSDm
MT5_SYMBOL_FALLBACKS=XAUUSD,XAUUSDm

# $30 demo — 10 × 0.01 lot XAU (Exness demo leverage usually enough)
MT5_LOT=0.01
MT5_MAGIC=880001

# Basket: open 10 at once, close ALL when combined profit hit, then open 10 new
MT5_BASKET_SIZE=10
MT5_BASKET_MIN_PROFIT=0.60
MT5_BASKET_MAX_LOSS=2.00
MT5_BATCH_OPEN_DELAY=0.4
MT5_ENTRY_COOLDOWN=15

MT5_STOP_LOSS_POINTS=350
MT5_MAX_HOLD_SECONDS=900
MT5_MAX_SPREAD_POINTS=65

# ~16% of $30 balance — stop for the day if hit
MT5_MAX_DAILY_LOSS=5.0
MT5_MAX_CONSEC_LOSSES=3
MT5_LOSS_PAUSE_SECONDS=1800

MT5_USE_SESSION=true
MT5_POLL_SECONDS=0.5
MT5_DEMO_ONLY=true
